# ═══════════════════════════════════════════════════════════════════
#  SamCity — muhit o'zgaruvchilari namunasi
#  Bu faylni `.env` deb nusxalang va qiymatlarni to'ldiring.
#  ⚠️ Haqiqiy `.env` ni HECH QACHON git'ga qo'shmang (.gitignore'da bor).
# ═══════════════════════════════════════════════════════════════════

# ── Django asosiy ────────────────────────────────────────────────
# Xavfsiz kalit yaratish:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=CHANGE-ME-uzun-tasodifiy-kalit
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.uz,www.yourdomain.uz
CSRF_TRUSTED_ORIGINS=https://yourdomain.uz,https://www.yourdomain.uz

# ── PostgreSQL (o'rnatilsa SQLite o'rniga ishlatiladi) ────────────
POSTGRES_DB=samcity
POSTGRES_USER=samcity
POSTGRES_PASSWORD=CHANGE-ME-db-parol
POSTGRES_HOST=db          # docker-compose'da xizmat nomi
POSTGRES_PORT=5432
DB_CONN_MAX_AGE=60

# ── Redis (channel layer + cache) ────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── CORS (mobil/web klient uchun) ────────────────────────────────
# Bo'sh qoldirsangiz: DEBUG=True'da hammaga ruxsat, False'da yopiq.
CORS_ALLOWED_ORIGINS=https://yourdomain.uz

# ── Xavfsizlik (DEBUG=False bo'lganda kuchga kiradi) ──────────────
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# ── JWT (mobil) ──────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=30

# ── To'lov shlyuzlari (Payme / Click) ────────────────────────────
PAYME_MERCHANT_ID=
PAYME_MERCHANT_KEY=
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_MERCHANT_USER_ID=

# ── SMS shlyuzi ──────────────────────────────────────────────────
# SMS_BACKEND: eskiz | playmobile | console (default dev'da console)
SMS_BACKEND=eskiz
SMS_ESKIZ_EMAIL=
SMS_ESKIZ_PASSWORD=
SMS_ESKIZ_FROM=4546
SMS_PLAYMOBILE_LOGIN=
SMS_PLAYMOBILE_PASSWORD=
SMS_PLAYMOBILE_FROM=3700

# ── Monitoring (ixtiyoriy — bo'sh bo'lsa o'chiq) ──────────────────
SENTRY_DSN=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# ── Media storage (Render free plan — disk saqlanmaydi!) ─────────
# Cloudinary (tavsiya): https://cloudinary.com — bepul rejada yetarli
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Yoki AWS S3 (Cloudinary o'rniga):
# AWS_STORAGE_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=
